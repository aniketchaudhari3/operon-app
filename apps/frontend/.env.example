# Supabase (Vercel + local)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Next.js server only (optional — admin ops; prefer RLS + anon key)
# SUPABASE_SERVICE_ROLE_KEY=

# Backend API URL (server-only — proxied via /api/pipelines/parse)
# Local dev:
BACKEND_URL=http://localhost:8000
# Separate Vercel backend project:
# BACKEND_URL=https://your-backend.vercel.app
# Monorepo on Vercel (same deployment): omit BACKEND_URL — auto-resolves to /_/backend
